# ========================================
# VedShare Environment Variables
# ========================================

# ----------------
# Database
# ----------------
MONGO_URI=mongodb+srv://your-connection-string
REDIS_URL=redis://your-redis-url

# ----------------
# JWT Tokens
# ----------------
ACCESS_TOKEN_SECRET=your-access-token-secret
REFRESH_TOKEN_SECRET=your-refresh-token-secret

# ----------------
# Email (For OTP)
# ----------------
SENDER_EMAIL=your-email@gmail.com
SENDER_EMAIL_PASSWORD=your-app-password

# ----------------
# Cloudinary (For uploads)
# ----------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ----------------
# Stripe Payments
# ----------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ----------------
# Firebase (Google Auth) - Backend
# ----------------
# Option 1: JSON Service Account Key (recommended for development)
# Paste the entire JSON content from Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Option 2: Individual credentials (for deployment)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ----------------
# reCAPTCHA v3 (Rate Limiting/Bot Protection)
# ----------------
# Get keys from: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# ----------------
# Environment
# ----------------
NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:5173
